#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>

/ {
    /* オートマウスレイヤー（layer 4）の自動有効化 */
    ib_tog_layer: ib_tog_layer {
        compatible = "zmk,input-behavior-tog-layer";
        #binding-cells = <1>;
        time-to-live-ms = <1000>;
    };

    /* スクロール感度スケーラー（INPUT_REL_WHEELのみ） */
    ib_wheel_scaler: ib_wheel_scaler {
        compatible = "zmk,input-behavior-scaler";
        #binding-cells = <2>;
        evt-type = <INPUT_EV_REL>;
        input-code = <INPUT_REL_WHEEL>;
    };

    /* 通常移動モード（layer 0〜4）: オートマウスレイヤーを有効化 */
    tb_mmv_ibl {
        compatible = "zmk,input-behavior-listener";
        device = <&pointing_device>;
        layers = <0 1 2 3 4>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
        x-invert;
        y-invert;
        scale-multiplier = <1>;
        scale-divisor = <1>;
        bindings = <&ib_tog_layer 4>;
    };

    /* スクロールモード（layer 5）: XをREL_MISCに逃がしYをホイールに変換 */
    tb_msl_ibl {
        compatible = "zmk,input-behavior-listener";
        device = <&pointing_device>;
        layers = <5>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_MISC>;
        y-input-code = <INPUT_REL_WHEEL>;
        y-invert;
        bindings = <&ib_wheel_scaler 1 4>;
    };
};

/* 既存のpointing_listenerはdisabledにする */
&pointing_listener {
    status = "disabled";
};
